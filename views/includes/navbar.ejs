<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<nav class="navbar navbar-expand-lg custom-navbar fixed-top">
  <div class="container">
    <!-- Logo -->
    <a class="navbar-brand fw-bold" href="/">
      🌿 HumanHood
    </a>

    <!-- Mobile Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Menu -->
    <div class="collapse navbar-collapse" id="navbarMain">

      <ul class="navbar-nav ms-auto me-7 align-items-lg-center">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/about">About</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/gallery">Gallery</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/donation">Donation</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/references">Reference</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/feedback">Feedback</a>
        </li>

        <% if (user) { %>
          <% if(user.role==="volunteer" ){ %>
            <li class="nav-item">
              <a class="nav-link" href="/volunteer/dashboard">Dashboard</a>
            </li>
            <% } %>
              <% if(user.role==="senior" ){ %>
                <li class="nav-item">
                  <a class="nav-link" href="/senior/dashboard">Dashboard</a>
                </li>
                <% } %>
                  <% if(user.role==="donor" ){ %>
                    <li class="nav-item">
                      <a class="nav-link" href="/donor/dashboard">Dashboard</a>
                    </li>
                    <% } %>
                      <!-- Username -->
                      <li class="nav-item ms-lg-3">
                        <span class="nav-user">
                          👋 <%= user.name %>
                        </span>
                      </li>
                      <!-- Logout -->
                      <li class="nav-item ms-lg-3">
                        <a class="btn btn-warning btn-sm nav-btn" href="/logout">
                          Logout
                        </a>
                      </li>
                      <% } else { %>
                        <li class="nav-item ms-lg-3">
                          <a class="btn btn-warning btn-sm nav-btn" href="/login">
                            Login
                          </a>
                        </li>
                        <% } %>

      </ul>
    </div>
  </div>
</nav>
