<head>
    <title>References</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
    <%- include('../includes/navbar') %>
        <%- include("../includes/toast") %>
            <div class="refrernce-header">
                <h1 class="page-title">Old Age Homes & NGO's</h1>
                <form method="GET" action="/references" class="filter-box">
                    <input type="text" name="search" placeholder=" Search NGO" class="search-input">
                    <select name="location" class="location-select">
                        <option value="">All Locations</option>
                        <option>Pune</option>
                        <option>Mumbai</option>
                        <option>Ahmednagar</option>
                    </select>
                    <button type="submit" class="search-btn">Search</button>
                </form>
            </div>
            <div class="container mt-4 mb-4">
                <div class="row g-4">
                    <% ngos.forEach(ngo=> { %>
                        <div class="col-lg-4 col-md-6 col-sm-12">
                            <div class="ngo-card">
                                <h3>
                                    <%= ngo.name %>
                                </h3>
                                <p><b>Location:</b>
                                    <%= ngo.location %>
                                </p>
                                <p><b>Phone:</b>
                                    <%= ngo.phone %>
                                </p>
                                <div class="needs">
                                    <% ngo.needs.forEach(need=> { %>
                                        <span class="tag">
                                            <%= need %>
                                        </span>
                                        <% }) %>
                                </div>
                                <a href="/ngo/<%= ngo._id %>" class="details-btn">View Details</a>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>
            <%- include('../includes/footer') %>
</body>