<head>
    <title>About HumanHood</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include("../includes/navbar") %>
        <%- include("../includes/toast") %>
            <main>
                <!-- hero section -->
                <section class="about-hero d-flex align-items-center text-center text-white">
                    <div class="container">
                        <h1 class="fw-bold display-4" data-aos="fade-up">Our Story of Compassion</h1>
                        <p class="lead mt-3" data-aos="fade-up" data-aos-delay="150">
                            Building bridges between Volunteers, Donors and Senior Citizens.
                        </p>
                    </div>
                </section>

                <!-- mission section-->
                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-md-6 mb-4 text-center" data-aos="fade-right">
                                <div class="mission-img-wrapper">
                                    <img src="/images/image1.png" class="mission-img">
                                </div>
                            </div>

                            <div class="col-md-6 mission-text" data-aos="fade-left">
                                <h2 class="fw-bold mb-3">Our Mission</h2>
                                <p class="text-muted">
                                    HumanHood was created to bring communities closer. We believe every
                                    senior citizen deserves care, respect and emotional support.
                                    Our platform connects volunteers and donors to create a safe
                                    and compassionate ecosystem.
                                </p>
                                <p class="text-muted">
                                    Through collaboration and kindness, we aim to build a society
                                    where no one feels alone and every senior feels valued.
                                </p>
                                <p class="text-muted">
                                    By encouraging meaningful interactions and community participation,
                                    HumanHood helps build stronger relationships between generations
                                    and promotes a culture of empathy and support.
                                </p>

                            </div>
                        </div>
                    </div>
                </section>

                <!-- values section -->
                <section class="py-5">
                    <div class="container text-center">
                        <h2 class="fw-bold mb-4">Our Core Values</h2>
                        <div class="row g-4">
                            <div class="col-md-4 mb-4" data-aos="zoom-in">
                                <div class="value-card p-4 shadow-sm rounded">
                                    <i class="fa-solid fa-hand-holding-heart text-success fa-2x mb-3"></i>
                                    <h5>Compassion</h5>
                                    <p class="text-muted">We lead with empathy and kindness in everything we do.</p>
                                </div>
                            </div>

                            <div class="col-md-4 mb-4" data-aos="zoom-in" data-aos-delay="150">
                                <div class="value-card p-4 shadow-sm rounded">
                                    <i class="fa-solid fa-people-group text-success fa-2x mb-3"></i>
                                    <h5>Community</h5>
                                    <p class="text-muted">We believe strong communities create meaningful change.</p>
                                </div>
                            </div>

                            <div class="col-md-4 mb-4" data-aos="zoom-in" data-aos-delay="300">
                                <div class="value-card p-4 shadow-sm rounded">
                                    <i class="fa-solid fa-shield-heart text-success fa-2x mb-3"></i>
                                    <h5>Trust</h5>
                                    <p class="text-muted">Transparency and respect are at the heart of our mission..</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </main>
            <%- include('../includes/footer') %>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
                <script>
                    AOS.init({
                        duration: 800,
                        once: true
                    });
                </script>
</body>