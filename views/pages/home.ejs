<html>

<head>
    <title>HumanHood | Compassionate Community</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(to bottom, #f8fafc, #eef2f7);
            color: #2c3e50;
        }

        /* SECTION SPACING */
        .section {
            padding: 90px 0;
        }

        .section-title {
            font-size: 2.4rem;
            font-weight: 700;
            margin-bottom: 50px;
            letter-spacing: 0.5px;
        }

        /* HERO (FULL SCREEN FIX 🔥) */
        .hero {
            height: 100vh;
            min-height: 100vh;
            background: url("/images/hero.jpeg") center/cover no-repeat;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            animation: zoomHero 20s ease-in-out infinite alternate;
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.35);
        }

        /* CONTENT */
        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 700px;
        }

        /* TEXT STYLING */
        .hero h1 {
            font-size: 3.2rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .hero h4 {
            font-weight: 500;
            opacity: 0.95;
        }

        .hero p {
            font-size: 1.15rem;
            opacity: 0.9;
        }

        /* BUTTON IMPROVEMENT */
        .hero .btn {
            padding: 12px 28px;
            font-weight: 600;
            border-radius: 8px;
            transition: 0.3s;
        }

        .hero .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        
        /* HERO ANIMATION */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* BUTTON ENHANCEMENT */
        .btn-success {
            border-radius: 30px;
            padding: 10px 25px;
            font-weight: 500;
            transition: 0.3s;
        }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(25, 135, 84, 0.3);
        }

        /* CARDS */
        .ui-card {
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            height: 100%;
        }

        .ui-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.15);
        }

        /* STATS */
        .stats-icon {
            width: 70px;
            height: 70px;
            background: #e8f7ef;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            margin-bottom: 15px;
            transition: 0.3s;
        }

        .ui-card:hover .stats-icon {
            transform: scale(1.1);
        }

        .stats-number {
            font-size: 2.8rem;
            font-weight: 700;
            color: #198754;
        }

        /* STEPS */
        .step-number {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: #198754;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            margin-bottom: 15px;
            font-size: 22px;
            font-weight: 700;
            transition: 0.3s;
        }

        .step-number:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 15px rgba(25, 135, 84, 0.3);
        }

        /* TEXT IMPROVEMENT */
        p {
            line-height: 1.7;
        }

        /* MOBILE OPTIMIZATION */
        @media(max-width:768px) {

            .hero {
                height: 100vh;
                padding: 20px;
            }

            .hero h1 {
                font-size: 2.4rem;
            }

            .hero p {
                font-size: 1rem;
            }

            .section {
                padding: 60px 0;
            }
        }
    </style>
</head>

<body>
    <%- include('../includes/navbar') %>
        <%- include("../includes/toast") %>
            <section class="hero">
                <div class="hero-overlay"></div>
                <div class="container hero-content text-center">
                    <h1>Welcome to HumanHood 🌿</h1>
                    <h4 class="mt-3">Hands to Heal, Hearts to Care 💚</h4>
                    <p class="mt-3">
                        Bringing Volunteers, Seniors & Donors together to build
                        a compassionate community.
                    </p>
                    <a href="/register" class="btn btn-success btn-lg mt-3">
                        Join the Community
                    </a>

                </div>
            </section>
            <!-- IMPACT -->
            <section class="section bg-light">
                <div class="container text-center">
                    <h2 class="section-title">Our Community Impact</h2>
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-4">
                            <div class="ui-card">
                                <div class="stats-icon"><i class="fa-solid fa-hands-helping text-success"></i></div>
                                <div class="stats-number">
                                    <%= volunteerCount %>
                                </div>
                                <p class="text-muted">Active Volunteers</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <div class="stats-icon"><i class="fa-solid fa-user text-success"></i></div>
                                <div class="stats-number">
                                    <%= seniorCount %>
                                </div>
                                <p class="text-muted">Senior Citizens Supported</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <div class="stats-icon"><i class="fa-solid fa-hand-holding-heart text-success"></i>
                                </div>
                                <div class="stats-number">
                                    <%= donorCount %>
                                </div>
                                <p class="text-muted">Generous Donors</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- HOW HUMANHOOD HELPS -->
            <section class="section">
                <div class="container text-center">
                    <h2 class="section-title">How HumanHood Helps</h2>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="ui-card"><i class="fa-solid fa-heart fa-2x text-success mb-3"></i>
                                <h5>Companionship</h5>
                                <p>Volunteers spend meaningful time with seniors and reduce loneliness.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card"><i class="fa-solid fa-users fa-2x text-success mb-3"></i>
                                <h5>Community</h5>
                                <p>HumanHood connects caring individuals with seniors who need support.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card"><i class="fa-solid fa-hand-holding-heart fa-2x text-success mb-3"></i>
                                <h5>Support</h5>
                                <p>Donations help provide essential resources for senior citizens.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ROLES -->
            <section class="section bg-light">
                <div class="container text-center">
                    <h2 class="section-title">Be Part of HumanHood</h2>
                    <div class="row g-4 justify-content-center">
                        <div class="col-md-4">
                            <div class="ui-card">
                                <i class="fa-solid fa-handshake fa-2x text-success mb-3"></i>
                                <h4>Volunteer</h4>
                                <p>Spend time with seniors and bring joy to their everyday lives.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <i class="fa-solid fa-user fa-2x text-success mb-3"></i>
                                <h4>Senior Citizen</h4>
                                <p>Receive companionship and support from caring volunteers.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <i class="fa-solid fa-hand-holding-dollar fa-2x text-success mb-3"></i>
                                <h4>Donor</h4>
                                <p>Support the community by donating essential resources.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- HOW IT WORKS -->
            <section class="section">
                <div class="container text-center">
                    <h2 class="section-title">How It Works</h2>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="step-number">1</div>
                            <h5>Register</h5>
                            <p>Create an account as volunteer, donor or senior citizen.</p>
                        </div>
                        <div class="col-md-4">
                            <div class="step-number">2</div>
                            <h5>Connect</h5>
                            <p>Volunteers and seniors connect and interact.</p>
                        </div>
                        <div class="col-md-4">
                            <div class="step-number">3</div>
                            <h5>Make Impact</h5>
                            <p>Every action helps build a compassionate society.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TESTIMONIAL -->
            <section class="section bg-light">
                <div class="container text-center">
                    <h2 class="section-title">Community Voices</h2>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="ui-card">
                                <p>"Volunteering through HumanHood has been a life-changing experience."</p>
                                <strong>- Volunteer</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <p>"I feel less lonely because volunteers visit me regularly."</p>
                                <strong>- Senior Citizen</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="ui-card">
                                <p>"Donating here feels meaningful because it directly helps people."</p>
                                <strong>- Donor</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <%- include('../includes/footer') %>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>