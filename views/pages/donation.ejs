<head>
    <title>Donate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../includes/navbar') %>
        <%- include("../includes/toast") %>
            <main class="main-content">
                <div class="donation-card p-4 shadow rounded bg-white">
                    <h2 class="text-center mb-4">Support Our Community 💚</h2>
                    <form action="/donation" method="post">
                        <input class="form-control mb-3" name="name" placeholder="Full Name" required>
                        <input class="form-control mb-3" type="email" name="email" placeholder="Email" required>
                        <select class="form-control mb-3" name="donationType" required>
                            <option value="">Donation Type</option>
                            <option value="Money">Money</option>
                            <option value="Clothes">Clothes</option>
                            <option value="Food">Food</option>
                            <option value="Other">Other Items</option>
                        </select>
                        <input class="form-control mb-3" type="number" name="amount"
                            placeholder="Donation Amount (if Money)">
                        <textarea class="form-control mb-3" name="description"
                            placeholder="Describe items (if Clothes/Food/Other)"></textarea>
                        <button class="btn btn-success w-100">Donate Now</button>
                    </form>
                </div>
            </main>

            <%- include('../includes/footer') %>
</body>

</html>