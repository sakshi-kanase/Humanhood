<head>
  <title>Donor Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <%- include('../includes/navbar') %>
    <div class="container donor-container">
      <h2 class="donor-welcome-text">
        Welcome <%= user.name %> 👋
      </h2>

      <hr>

      <!-- Donor Profile -->

      <div class="card donor-profile-card">
        <h4 class="donor-section-title">Donor Information</h4>
        <div class="row">
          <div class="col-md-4">
            <p><strong>Name:</strong>
              <%= user.name %>
            </p>
          </div>
          <div class="col-md-4">
            <p><strong>Email:</strong>
              <%= user.email %>
            </p>
          </div>
          <div class="col-md-4">
            <p><strong>Role:</strong>
              <%= user.role %>
            </p>
          </div>
        </div>
      </div>

      <!-- Donation Stats -->

      <div class="row donor-stats-row">
        <div class="col-md-4">
          <div class="card donor-stat-card text-center">
            <h5>Total Donations</h5>
            <h2 class="donor-stat-number">
              <%= totalDonations %>
            </h2>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card donor-stat-card text-center">
            <h5>Total Money Donated</h5>
            <h2 class="stat-number">₹<%= totalMoney %>
            </h2>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card donor-stat-card text-center">
            <h5>Items Donated</h5>
            <h2 class="stat-number">
              <%= itemsDonated %>
            </h2>
          </div>
        </div>
      </div>

      <!-- Donation History -->

      <div class="card donor-donation-history-card">
        <h4 class="section-title">Donation History</h4>
        <table class="table table-bordered table-hover donor-table">
          <thead class="table-light">
            <tr>
              <th>Type</th>
              <th>Amount</th>
              <th>Description</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if(donations.length===0){ %>
              <tr>
                <td colspan="5" class="text-center text-muted">
                  No donations yet
                </td>
              </tr>
              <% } %>
                <% donations.forEach(d=> { %>
                  <tr>
                    <td>
                      <%= d.donationType %>
                    </td>
                    <td>
                      <%= d.amount || "-" %>
                    </td>
                    <td>
                      <%= d.description || "-" %>
                    </td>
                    <td>
                      <% if(d.status==="Delivered" ){ %>
                        <span class="badge bg-success">
                          <%= d.status %>
                        </span>
                        <% } else if(d.status==="Received" ){ %>
                          <span class="badge bg-primary">
                            <%= d.status %>
                          </span>
                          <% } else { %>
                            <span class="badge bg-warning text-dark">
                              <%= d.status %>
                            </span>
                            <% } %>
                    </td>
                    <td>
                      <%= new Date(d.date).toDateString() %>
                    </td>
                  </tr>
                  <% }) %>
          </tbody>
        </table>
        <div class="text-end mt-4">
          <a href="/donation" class="btn donor-donate-btn">
            Donate Again
          </a>
        </div>
      </div>
    </div>
    <%- include('../includes/footer') %>
</body>