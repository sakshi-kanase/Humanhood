<head>
    <title>Volunteer Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('../includes/navbar') %>

        <div class="container dashboard-container mt-4">
            <div class="welcome-header mb-4">
                <h2>
                    Welcome <%= user.name %>
                </h2>
                <p class="text-muted">
                    Here is your volunteer dashboard
                </p>
            </div>


            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow profile-card ">
                        <div class="card-body">
                            <h4>Volunteer Profile</h4>
                            <p><strong>Name:</strong>
                                <%= user.name %>
                            </p>
                            <p><strong>Email:</strong>
                                <%= user.email %>
                            </p>
                            <p><strong>Role:</strong>
                                <%= user.role %>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="card text-center stats-card  shadow">
                                <div class="card-body">
                                    <h6>Total Donations</h6>
                                    <h3 class="text-success">
                                        <%= totalDonations %>
                                    </h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card text-center stats-card  shadow">
                                <div class="card-body">
                                    <h6>Money Donated</h6>
                                    <h3 class="text-success">
                                        ₹<%= totalMoney %>
                                    </h3>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card text-center stats-card  shadow">
                                <div class="card-body">
                                    <h6>Items Donated</h6>
                                    <h3 class="text-success">
                                        <%= itemsDonated %>
                                    </h3>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

            <div class="mt-5">
                <h4 class="mb-3">Recent Senior Visits</h4>
                <table class="table table-bordered table-hover shadow">

                    <thead class="table-light">
                        <tr>
                            <th>Senior Name</th>
                            <th>Visit Date</th>
                            <th>Activity</th>
                            <th>Feedback</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if(visits.length===0){ %>
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No visits yet
                                </td>
                            </tr>

                            <% } %>

                                <% visits.forEach(v=> { %>
                                    <tr>
                                        <td>
                                            <%= v.seniorName %>
                                        </td>
                                        <td>
                                            <%= new Date(v.visitDate).toDateString() %>
                                        </td>
                                        <td>
                                            <%= v.activity || "-" %>
                                        </td>
                                        <td>
                                            <%= v.feedback || "No feedback" %>
                                        </td>
                                    </tr>
                                    <% }) %>

                    </tbody>
                </table>
            </div>

            <div class="mt-5">
                <h4 class="mb-3 ">Donation History</h4>
                <table class="table table-bordered shadow">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% donations.forEach(d=> { %>
                            <tr>
                                <td>
                                    <%= d.donationType %>
                                </td>
                                <td>
                                    <%= d.amount || "-" %>
                                </td>
                                <td>
                                    <%= d.description || "-" %>
                                </td>
                                <td>
                                    <span class="badge bg-warning">
                                        <%= d.status %>
                                    </span>
                                </td>
                                <td>
                                    <%= d.date.toDateString() %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <%- include('../includes/footer') %>

</body>